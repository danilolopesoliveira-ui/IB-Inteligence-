# ============================================================
# IB-Agents — Environment Variables Template
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Modelos (pode substituir por outros modelos compatíveis)
ORCHESTRATOR_MODEL=claude-opus-4-6
AGENT_MODEL=claude-sonnet-4-6

# ChromaDB (RAG local)
CHROMA_DB_PATH=./memory/chroma_db
CHROMA_COLLECTION_NAME=ib_analyses

# Configurações de output
OUTPUT_DIR=./output
TEMPLATE_DIR=./templates

# Configurações de análise
DEFAULT_CURRENCY=BRL
DEFAULT_LANGUAGE=pt-BR
RISK_FREE_RATE=0.1375
EQUITY_RISK_PREMIUM=0.055
COUNTRY_RISK_PREMIUM=0.028

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
